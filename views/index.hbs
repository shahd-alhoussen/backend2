
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>back-end3</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen font-sans">

    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md mx-4 transform transition-all ">
        
        <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">☀️ Weather App</h2>
        
        <form id="form1" class="space-y-4">
            <div>
                <label for="address" class="block text-sm font-medium text-gray-600 mb-1">Enter Location:</label>
                <input type="text" id="address" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            </div>

            <button id="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg shadow transition duration-200">
                Get Weather
            </button>

           
                <p id="location" class="font-medium text-lg text-blue-900"> Location:  {{location}}</p>
                <p id="forcast" class="font-medium text-lg text-blue-900"> Temperature: {{forcast}}°C</p>
                <p id="latitude"  class="font-medium text-lg text-blue-900">Latitude: {{latitude}}</p>
                <p id="longitude"  class="font-medium text-lg text-blue-900">Longitude: {{longitude}}</p>
                <p id="error" class="text-sm text-red-500 font-medium text-center mt-2">{{error}}</p>
           
        </form>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>